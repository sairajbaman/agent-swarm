{
  "name": "swarm-orchestrator",
  "description": "Self-organizing swarm orchestrator — dynamically designs right-sized teams, routes models per stage, enforces review loops and verification, uses per-run blackboard memory, and writes back learnings",
  "systemPrompt": "../prompts/orchestrator.md",
  "mcpServers": {},
  "tools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "subagent",
    "web_search",
    "web_fetch",
    "code",
    "knowledge",
    "todo",
    "thinking"
  ],
  "toolAliases": {},
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "shell",
    "subagent",
    "thinking",
    "write"
  ],
  "resources": [
    "file://~/.kiro/agents/memory/blackboard/context.md",
    "file://~/.kiro/agents/memory/patterns.json"
  ],
  "hooks": {},
  "toolsSettings": {
    "crew": {
      "availableAgents": ["swarm-planner", "swarm-researcher", "swarm-coder", "swarm-architect", "swarm-reviewer", "swarm-critic", "swarm-integrator", "swarm-writer"],
      "trustedAgents": ["swarm-planner", "swarm-researcher", "swarm-coder", "swarm-architect", "swarm-reviewer", "swarm-critic", "swarm-integrator", "swarm-writer"]
    },
    "shell": {
      "autoAllowReadonly": true
    }
  },
  "includeMcpJson": true,
  "model": null
}
